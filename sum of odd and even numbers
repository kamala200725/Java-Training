import java.util.*;
class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n,sum=0,sum1=0;
        n=sc.nextInt();
        for (int i=1;i<=n;i++){
            if (i%2==0){
                sum=sum+i;
            }
            else{
                sum1=sum1+i;
            }


        }
        System.out.println("Sum of odd numbers:"+sum1);
        System.out.println("Sum of even numbers:"+sum);
    }
}
