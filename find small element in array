import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n;
        n=sc.nextInt();
        int[]a=new int[n];
        for (int i=0;i<n;i++){
            a[i]=sc.nextInt();
        }
        int s=a[0];
        for(int i=0;i<n;i++){
            if(s>a[i])
            {
                s=a[i];
            }
        }
        System.out.println(s);
    }
}
